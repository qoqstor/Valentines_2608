rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /letters/{id} {
      allow read: if true;
      allow create: if
        (request.resource.data.text == null || request.resource.data.text.size() < 2000) &&
        (!('audioData' in request.resource.data) || request.resource.data.audioData == null || request.resource.data.audioData.size() < 900000);
    }
    match /guesses/{id} {
      allow read, write: if true;
    }
    match /meta/{id} {
      allow read, write: if true;
    }
    match /users/{uid} {
      allow read, write: if true;
    }
  }
}